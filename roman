#include <stdio.h>
#include <string.h>

// Function to return the decimal value of a single Roman character
int romanValue(char c) {
    switch (c) {
        case 'I': return 1;
        case 'V': return 5;
        case 'X': return 10;
        case 'L': return 50;
        case 'C': return 100;
        case 'D': return 500;
        case 'M': return 1000;
        default:  return 0;
    }
}

// Function to convert the Roman numeral string to an integer
int romanToInt(char *s) {
    int total = 0;
    int len = strlen(s);

    for (int i = 0; i < len; i++) {
        int current = romanValue(s[i]);
        
        // If the next character has a higher value, subtract the current value
        if (i + 1 < len && romanValue(s[i + 1]) > current) {
            total -= current;
        } else {
            total += current;
        }
    }

    return total;
}

int main() {
    char num[] = "XC";
    printf("Input: num = \"%s\"\n", num);
    printf("Output: %d\n", romanToInt(num));
    return 0;
}
