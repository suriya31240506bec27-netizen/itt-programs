#include<stdio.h>
#include<stdlib.h>
int rev(int n)
{
int val = 0;
while(n > 0)
{
val = val*10 + n % 10;
n /= 10;
}
return val;
}
int isPal(int n)
{
return (rev(n) == n);
}
