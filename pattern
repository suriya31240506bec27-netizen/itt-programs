#include <stdio.h>

int main() {
    int n = 5; // Controls the size of the diamond (half-height)

    // 1. Top half of the pattern
    for (int i = n; i >= 1; i--) {
        // Left stars
        for (int j = 1; j <= i; j++) {
            printf("* ");
        }
        // Center spaces
        for (int j = 1; j <= 2 * (n - i); j++) {
            printf("  ");
        }
        // Right stars
        for (int j = 1; j <= i; j++) {
            printf("* ");
        }
        printf("\n");
    }

    // 2. Bottom half of the pattern
    for (int i = 2; i <= n; i++) {
        // Left stars
        for (int j = 1; j <= i; j++) {
            printf("* ");
        }
        // Center spaces
        for (int j = 1; j <= 2 * (n - i); j++) {
            printf("  ");
        }
        // Right stars
        for (int j = 1; j <= i; j++) {
            printf("* ");
        }
        printf("\n");
    }

    return 0;
}
